# ##############################################################################
# Git Ignore - Angular
# ##############################################################################

# Dependency directories
node_modules/

# Compiled output
dist/
tmp/
out-tsc/
bazel-out/

# IDEs and editors
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.swp
*.swo
.DS_Store

# Angular cache
.angular/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS metadata
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local
.env.*.local

# Optional: TypeScript build info
*.tsbuildinfo
